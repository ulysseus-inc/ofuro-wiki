# =============================================================
# ofuro-wiki バックエンド 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# =============================================================

# ----- データベース -----
# PostgreSQL パスワード（docker-compose でも使用）
# 生成コマンド: openssl rand -base64 24
POSTGRES_PASSWORD="CHANGE_ME_DB_PASSWORD"

# PostgreSQL 接続URL（POSTGRES_PASSWORD と同じパスワードを設定）
DATABASE_URL="postgresql://ofuro:CHANGE_ME_DB_PASSWORD@localhost:5432/ofuro_wiki"

# ----- セキュリティ -----
# JWT署名シークレット（本番では必ず強いランダム値を設定）
# 生成コマンド: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_STRONG_RANDOM_SECRET"

# ----- CORS -----
# * : 全てのオリジンを許可（デフォルト）
# ドメインを絞る場合はカンマ区切りで指定
# ALLOWED_ORIGINS=https://wiki.example.com
# ALLOWED_ORIGINS=https://wiki.example.com,https://wiki2.example.com
ALLOWED_ORIGINS=*

# ----- アプリケーション -----
NODE_ENV="development"
PORT=3010

# クッキーのセキュアフラグ（HTTPS環境では true、HTTP環境では false）
# 未設定の場合: NODE_ENV=production なら true、それ以外は false
# HTTPS（本番/GCE）: COOKIE_SECURE=true  ← 省略可
# HTTP（社内ローカル等）: COOKIE_SECURE=false
# COOKIE_SECURE=false

# サーバーのベースURL（メール内リンク生成に使用）
BASE_URL="http://localhost:8080"

# ストレージパス
BLOB_STORAGE_PATH="./data/blobs"
BACKUP_STORAGE_PATH="./data/backups"

# アプリバージョン（リリース時にコメントを外して値を設定する）
# ※ AFFINE_API_VERSION（config.service.ts）は絶対に変更しないこと
# APP_VERSION=1.0.0

# ----- 管理者 -----
# 初回起動時に Admin として登録するメールアドレス
# ADMIN_EMAIL=admin@example.com

# ----- メール（SMTP）- オプション -----
# 未設定の場合はメール機能が無効になります
# MAILER_HOST=smtp.example.com
# MAILER_PORT=587
# MAILER_USER=user@example.com
# MAILER_PASSWORD=smtp_password
# MAILER_SENDER="ofuro-wiki <noreply@example.com>"
# MAILER_IGNORE_TLS=false
